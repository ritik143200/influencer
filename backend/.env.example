# Database Configuration
# Use MongoDB Atlas for live deployment.
# Example: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/viralmantrix?retryWrites=true&w=majority
MONGODB_URI=
MONGO_MAX_POOL_SIZE=50
MONGO_SERVER_SELECTION_TIMEOUT_MS=7000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_AUTO_INDEX=true

# In production this should stay true so a broken DB config fails fast.
# Local preview can keep this false if MongoDB is not running.
REQUIRE_DATABASE=false

# JWT / Session Secrets
JWT_SECRET=
SESSION_SECRET=

# Server Port
PORT=5002
NODE_ENV=development

# Email Configuration (Nodemailer)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# Frontend URL
# FRONTEND_URL can be one URL or comma-separated URLs for CORS.
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:4174
